# Lookout Device Dashboard Configuration
# Copy this file to .env and configure for your environment

# ============================================
# Flask Application Settings
# ============================================
SECRET_KEY=your-secret-key-change-in-production
DEBUG=false
FLASK_ENV=production

# ============================================
# Authentication Settings (IMPORTANT for Production)
# ============================================

# Option 1: Set users directly in environment variable
# Format: "username:password,username2:password2"
# AUTH_USERS=admin:your-secure-password,user:another-password

# Option 2: Load users from a JSON file (more secure for production)
# File format: {"admin": "plaintext:password"} or {"admin": "pbkdf2:sha256:..."}
# AUTH_USERS_FILE=./users.json

# If neither is set and FLASK_ENV != production, demo credentials are used:
# admin:admin123, user:user123
# WARNING: Demo credentials should NEVER be used in production!

# ============================================
# Lookout API Settings
# ============================================
LOOKOUT_APPLICATION_KEY=your-application-key-here
USE_SAMPLE_DATA=false

# ============================================
# Cache Settings (IMPORTANT for Large Fleets)
# ============================================

# Enable in-memory caching (recommended: true)
CACHE_ENABLED=true

# How long cached data is considered valid (in minutes)
# Recommended: 30-60 for large fleets to reduce API calls
CACHE_MAX_AGE_MINUTES=60

# ============================================
# SQLite Persistence Settings (IMPORTANT!)
# ============================================

# Enable SQLite disk cache (recommended: true for large fleets)
# This persists device data across app restarts
ENABLE_DISK_CACHE=true

# Where to store the SQLite cache file
CACHE_FILE_PATH=./device_cache.db

# ============================================
# Auto-Refresh Settings (NEW!)
# ============================================

# Auto-load device data on startup if cache is empty/stale
# Recommended: true for seamless experience
AUTO_REFRESH_ON_STARTUP=true

# Enable background refresh worker thread
# Recommended: true for large fleets to keep data fresh
# If false, data only refreshes when users trigger it
BACKGROUND_REFRESH_ENABLED=true

# How often to check and refresh cache in background (minutes)
# Recommended: 30-60 minutes to balance freshness vs API load
BACKGROUND_REFRESH_INTERVAL_MINUTES=30

# ============================================
# Delta Sync Settings
# ============================================

# Use delta sync to fetch only changed devices (more efficient)
ENABLE_DELTA_SYNC=true

# How far back to look for changes (hours)
DELTA_SYNC_LOOKBACK_HOURS=24

# ============================================
# API Settings
# ============================================

# API request timeout (seconds)
API_TIMEOUT=30

# Number of retry attempts for failed API calls
API_RETRY_ATTEMPTS=3

# Maximum devices per API request (API max is 1000)
MAX_DEVICES_PER_REQUEST=1000

# ============================================
# Logging Settings
# ============================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (leave empty for console only)
# LOG_FILE=./dashboard.log

# ============================================
# Server Settings
# ============================================

# Host and port for Flask server
HOST=127.0.0.1
PORT=5001

# Enable threading for better performance
ENABLE_THREADING=true

# ============================================
# Proxy Settings (for Secure Environments)
# ============================================

# HTTP/HTTPS proxy URL (e.g., http://proxy.example.com:8080)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080

# Comma-separated list of hosts to bypass proxy
# NO_PROXY=localhost,127.0.0.1

# SSL verification through proxy (set to false only if using corporate proxy with custom CA)
PROXY_VERIFY_SSL=true

# Path to custom CA certificate bundle for proxy connections
# PROXY_CA_BUNDLE=/path/to/ca-bundle.crt

# ============================================
# Recommended Configurations by Fleet Size
# ============================================

# SMALL FLEET (< 1,000 devices):
# CACHE_MAX_AGE_MINUTES=30
# BACKGROUND_REFRESH_ENABLED=false
# ENABLE_DISK_CACHE=false

# MEDIUM FLEET (1,000 - 10,000 devices):
# CACHE_MAX_AGE_MINUTES=60
# BACKGROUND_REFRESH_ENABLED=true
# BACKGROUND_REFRESH_INTERVAL_MINUTES=30
# ENABLE_DISK_CACHE=true

# LARGE FLEET (10,000+ devices):
# CACHE_MAX_AGE_MINUTES=120
# BACKGROUND_REFRESH_ENABLED=true
# BACKGROUND_REFRESH_INTERVAL_MINUTES=60
# ENABLE_DISK_CACHE=true
# ENABLE_DELTA_SYNC=true
